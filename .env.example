# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=asm_user
POSTGRES_PASSWORD=asm_password
POSTGRES_DB=asm_db
POSTGRES_PORT=5432

# ── API ────────────────────────────────────────────────
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://asm_user:asm_password@db:5432/asm_db
LOG_LEVEL=info

# ── Groq / LangChain ─────────────────────────────────
GROQ_API_KEY=gsk_your-key-here
LLM_MODEL=llama3-70b-8192
