# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=asm_user
POSTGRES_PASSWORD=asm_password
POSTGRES_DB=asm_db
POSTGRES_PORT=5432

# ── API ────────────────────────────────────────────────
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://asm_user:asm_password@db:5432/asm_db
LOG_LEVEL=info

# ── OpenAI / LangChain ────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
